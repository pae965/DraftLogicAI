APP_NAME="RUS Research CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=th
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== Database (MySQL 5.7+ with utf8mb4) =====
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=DraftLogicAI
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===== AI Providers (default keys for testing — production should use BYOK per user) =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
OPENAI_DEFAULT_MODEL=gpt-4o-mini
GEMINI_DEFAULT_MODEL=gemini-1.5-flash

# ===== RUS specific config =====
RUS_INSTITUTION_TH="มหาวิทยาลัยเทคโนโลยีราชมงคลสุวรรณภูมิ"
RUS_INSTITUTION_EN="Rajamangala University of Technology Suvarnabhumi"
RUS_INSTITUTION_SHORT="RUS"
RUS_FACULTY_TH_DEFAULT="คณะนิติศาสตร์"
RUS_FACULTY_EN_DEFAULT="Faculty of Law"

# ===== Export =====
EXPORT_FONT_PATH=public/fonts/th-sarabun-new
EXPORT_PDF_TIMEOUT=60
EXPORT_MAX_PAGES=25

VITE_APP_NAME="${APP_NAME}"
